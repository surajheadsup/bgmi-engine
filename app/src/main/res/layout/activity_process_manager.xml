<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Header bar with background -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="?attr/colorSurfaceContainerHigh"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="12dp" android:paddingBottom="12dp"
        android:elevation="2dp">
        <TextView android:id="@+id/btnBack"
            android:layout_width="36dp" android:layout_height="36dp"
            android:text="←" android:textColor="@color/accent" android:textSize="16sp"
            android:gravity="center" android:background="@drawable/btn_back" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Process Manager" android:textColor="@color/accent" android:textSize="18sp"
            android:textStyle="bold" android:layout_marginStart="12dp" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:padding="14dp">

    <!-- Status -->
    <TextView android:id="@+id/tvProcessStatus" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Tap Refresh" android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="11sp" />
    <TextView android:id="@+id/tvWhitelistInfo" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="No whitelisted apps"
        android:textColor="@color/success" android:textSize="10sp" android:layout_marginBottom="8dp"
        android:ellipsize="end" android:singleLine="true" />

    <!-- Action buttons — compact row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="8dp">

        <TextView android:id="@+id/btnRefresh"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Refresh" android:textColor="?attr/colorOnSurface" android:textSize="11sp"
            android:textStyle="bold" android:gravity="center" android:background="@drawable/toggle_btn_bg"
            android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="3dp" />

        <TextView android:id="@+id/btnKillAll"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Kill All" android:textColor="@color/danger" android:textSize="11sp"
            android:textStyle="bold" android:gravity="center" android:background="@drawable/toggle_btn_bg"
            android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp" />

        <TextView android:id="@+id/btnKillSelected"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="Kill Sel." android:textColor="@color/warning" android:textSize="11sp"
            android:textStyle="bold" android:gravity="center" android:background="@drawable/toggle_btn_bg"
            android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp" />

        <TextView android:id="@+id/btnManageWhitelist"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="🛡 List" android:textColor="@color/success" android:textSize="11sp"
            android:textStyle="bold" android:gravity="center" android:background="@drawable/toggle_btn_bg"
            android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginStart="3dp" />
    </LinearLayout>

    <!-- Search -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" app:boxBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:hintTextColor="?attr/colorOutline">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Search apps..."
            android:textColor="?attr/colorOnSurface" android:textSize="13sp" android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Filter tabs -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="6dp">
        <TextView android:id="@+id/btnFilterAll" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="ALL" android:textColor="@color/accent" android:textSize="11sp"
            android:textStyle="bold" android:gravity="center" android:background="@drawable/toggle_btn_bg"
            android:paddingTop="6dp" android:paddingBottom="6dp" android:layout_marginEnd="3dp" />
        <TextView android:id="@+id/btnFilterUser" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="USER" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp"
            android:textStyle="bold" android:gravity="center" android:background="@drawable/toggle_btn_bg"
            android:paddingTop="6dp" android:paddingBottom="6dp" android:layout_marginStart="3dp" android:layout_marginEnd="3dp" />
        <TextView android:id="@+id/btnFilterSystem" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="SYSTEM" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp"
            android:textStyle="bold" android:gravity="center" android:background="@drawable/toggle_btn_bg"
            android:paddingTop="6dp" android:paddingBottom="6dp" android:layout_marginStart="3dp" />
    </LinearLayout>

    <!-- Column header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="6dp" android:paddingEnd="6dp" android:layout_marginBottom="4dp">
        <TextView android:layout_width="20dp" android:layout_height="wrap_content"
            android:text="✓" android:textColor="?attr/colorOutline" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="App" android:textColor="?attr/colorOutline" android:textSize="9sp" android:layout_marginStart="6dp" />
        <TextView android:layout_width="42dp" android:layout_height="wrap_content"
            android:text="RAM" android:textColor="?attr/colorOutline" android:textSize="9sp" android:gravity="end" />
        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="🛡" android:textColor="?attr/colorOutline" android:textSize="9sp" android:gravity="center" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvProcesses"
        android:layout_width="match_parent" android:layout_height="match_parent" />
</LinearLayout>
</LinearLayout>
