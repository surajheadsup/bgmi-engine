<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══ HEADER ═══ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp" android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BGMI ENGINE PRO" android:textColor="@color/accent"
                    android:textSize="22sp" android:textStyle="bold" android:letterSpacing="0.05" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Smart Gaming Assistant" android:textColor="?attr/colorOutline"
                    android:textSize="11sp" android:layout_marginTop="2dp" />
            </LinearLayout>
            <!-- Live stats badges -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="end">
                <TextView android:id="@+id/tvSysBattery" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🔋 --%" android:textColor="@color/success"
                    android:textSize="13sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvSysTemp" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🌡 --°C" android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ SYSTEM STATS BAR ═══ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp"
            android:background="@drawable/overlay_bg" android:padding="10dp">
            <TextView android:id="@+id/tvSysRam" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="RAM --" android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp" android:gravity="center" />
            <View android:layout_width="1dp" android:layout_height="14dp" android:background="?attr/colorOutlineVariant" />
            <TextView android:id="@+id/tvSysCpu" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="CPU --" android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="11sp" android:gravity="center" />
            <View android:layout_width="1dp" android:layout_height="14dp" android:background="?attr/colorOutlineVariant" />
            <TextView android:id="@+id/tvSysProcs" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Apps --"
                android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp" android:gravity="center" />
            <View android:layout_width="1dp" android:layout_height="14dp" android:background="?attr/colorOutlineVariant" />
            <TextView android:id="@+id/btnQuickKill" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💀 Kill" android:textColor="@color/danger" android:textSize="11sp" android:textStyle="bold"
                android:paddingStart="10dp" android:paddingEnd="4dp" />
        </LinearLayout>

        <!-- ═══ PERMISSIONS ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardBackgroundColor="?attr/colorSurfaceContainerHigh" app:cardCornerRadius="12dp"
            app:cardElevation="0dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PERMISSIONS" android:textColor="?attr/colorOutline" android:textSize="10sp"
                    android:textStyle="bold" android:letterSpacing="0.15" android:layout_marginBottom="10dp" />

                <!-- Shizuku -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <View android:id="@+id/dotShizuku" android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/dot_green" />
                    <TextView android:id="@+id/tvShizukuStatus" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Shizuku" android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                        android:layout_marginStart="10dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnGrantShizuku"
                        android:layout_width="wrap_content" android:layout_height="30dp"
                        android:text="Setup" android:textSize="10sp" android:visibility="gone"
                        app:backgroundTint="@color/accent" android:textColor="#FFFFFF" android:padding="0dp" android:insetTop="0dp"
                        android:insetBottom="0dp" android:minWidth="0dp" android:minHeight="0dp"
                        android:paddingStart="12dp" android:paddingEnd="12dp" />
                </LinearLayout>
                <TextView android:id="@+id/tvShizukuGuide" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="@string/shizuku_install_guide"
                    android:textColor="@color/warning" android:textSize="10sp" android:visibility="gone"
                    android:layout_marginBottom="6dp" android:layout_marginStart="18dp" />

                <!-- Usage -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <View android:id="@+id/dotUsage" android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/dot_green" />
                    <TextView android:id="@+id/tvUsageStatus" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Usage Access" android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                        android:layout_marginStart="10dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnGrantUsage"
                        android:layout_width="wrap_content" android:layout_height="30dp"
                        android:text="Grant" android:textSize="10sp" android:visibility="gone"
                        app:backgroundTint="@color/accent" android:textColor="#FFFFFF" android:padding="0dp" android:insetTop="0dp"
                        android:insetBottom="0dp" android:minWidth="0dp" android:minHeight="0dp"
                        android:paddingStart="12dp" android:paddingEnd="12dp" />
                </LinearLayout>

                <!-- Overlay -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <View android:id="@+id/dotOverlay" android:layout_width="8dp" android:layout_height="8dp"
                        android:background="@drawable/dot_green" />
                    <TextView android:id="@+id/tvOverlayStatus" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Overlay" android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                        android:layout_marginStart="10dp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnGrantOverlay"
                        android:layout_width="wrap_content" android:layout_height="30dp"
                        android:text="Grant" android:textSize="10sp" android:visibility="gone"
                        app:backgroundTint="@color/accent" android:textColor="#FFFFFF" android:padding="0dp" android:insetTop="0dp"
                        android:insetBottom="0dp" android:minWidth="0dp" android:minHeight="0dp"
                        android:paddingStart="12dp" android:paddingEnd="12dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ ENGINE CONTROL ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardBackgroundColor="?attr/colorSurfaceContainerHigh" app:cardCornerRadius="12dp"
            app:cardElevation="0dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvEngineStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Engine Stopped"
                            android:textColor="?attr/colorOnSurfaceVariant" android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvEngineMode" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="@color/success"
                            android:textSize="12sp" android:textStyle="bold" android:visibility="gone" />
                    </LinearLayout>
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnStartStop"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="START" android:textSize="12sp" android:textStyle="bold"
                        app:backgroundTint="@color/accent" android:textColor="#FFFFFF" android:padding="0dp" android:insetTop="0dp"
                        android:insetBottom="0dp" android:minWidth="0dp" android:minHeight="0dp"
                        android:paddingStart="24dp" android:paddingEnd="24dp"
                        app:cornerRadius="20dp" />
                </LinearLayout>

                <TextView android:id="@+id/tvSessionInfo" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="?attr/colorOutline"
                    android:textSize="11sp" />
                <TextView android:id="@+id/tvStatsInfo" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="?attr/colorOutline"
                    android:textSize="10sp" android:visibility="gone" android:layout_marginTop="2dp" />

                <!-- Override -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/colorOutlineVariant" android:layout_marginTop="10dp" android:layout_marginBottom="8dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Manual Override" android:textColor="?attr/colorOnSurface" android:textSize="13sp" />
                        <TextView android:id="@+id/tvOverrideStatus" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Auto mode (heat-based)"
                            android:textColor="@color/success" android:textSize="10sp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchOverride"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        app:thumbTint="@color/accent" app:trackTint="?attr/colorOutlineVariant" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ DEVICE STATUS ═══ -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardDeviceStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" app:cardBackgroundColor="?attr/colorSurfaceContainerLow" app:cardCornerRadius="12dp"
            app:cardElevation="0dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DEVICE STATUS" android:textColor="?attr/colorOutline" android:textSize="10sp"
                    android:textStyle="bold" android:letterSpacing="0.15" android:layout_marginBottom="6dp" />

                <!-- Action buttons — separate row, visible -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/btnApplyNow" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="▶ Apply" android:textColor="@color/success"
                        android:textSize="12sp" android:textStyle="bold" android:gravity="center"
                        android:background="@drawable/toggle_btn_bg"
                        android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="4dp" />
                    <TextView android:id="@+id/btnRestoreAll" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="↺ Restore" android:textColor="@color/danger"
                        android:textSize="12sp" android:textStyle="bold" android:gravity="center"
                        android:background="@drawable/toggle_btn_bg"
                        android:paddingTop="8dp" android:paddingBottom="8dp"
                        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" />
                    <TextView android:id="@+id/btnCopyStatus" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="📋 Copy" android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" android:textStyle="bold" android:gravity="center"
                        android:background="@drawable/toggle_btn_bg"
                        android:paddingTop="8dp" android:paddingBottom="8dp"
                        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" />
                    <TextView android:id="@+id/btnRefreshStatus" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="↻ Read" android:textColor="@color/info"
                        android:textSize="12sp" android:textStyle="bold" android:gravity="center"
                        android:background="@drawable/toggle_btn_bg"
                        android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginStart="4dp" />
                </LinearLayout>

                <TextView android:id="@+id/tvDeviceStatusUpdated" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Tap Read to check device state"
                    android:textColor="?attr/colorOutline" android:textSize="9sp" android:layout_marginBottom="6dp" />

                <!-- 2-column status grid -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvLiveShizuku" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="⚙ Shizuku: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" android:layout_marginBottom="3dp" />
                        <TextView android:id="@+id/tvLiveRefreshRate" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="🖥 Refresh: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" android:layout_marginBottom="3dp" />
                        <TextView android:id="@+id/tvLivePerfMode" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="⚡ BatSaver: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" android:layout_marginBottom="3dp" />
                        <TextView android:id="@+id/tvLiveBrightness" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="☀ Bright: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" android:layout_marginBottom="3dp" />
                        <TextView android:id="@+id/tvLiveBrightnessMode" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="☀ Mode: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tvLiveDns" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="📶 DNS: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" android:layout_marginBottom="3dp" />
                        <TextView android:id="@+id/tvLiveGpu" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="🎮 Adaptive: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" android:layout_marginBottom="3dp" />
                        <TextView android:id="@+id/tvLivePointerSpeed" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="👆 Touch: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" android:layout_marginBottom="3dp" />
                        <TextView android:id="@+id/tvLiveDnd" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="🔇 DND: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" android:layout_marginBottom="3dp" />
                        <TextView android:id="@+id/tvLiveTemp" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="🌡 Temp: --"
                            android:textColor="?attr/colorOutline" android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
                <TextView android:id="@+id/tvLiveUser" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🔑 Shell: --"
                    android:textColor="?attr/colorOutline" android:textSize="10sp" android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ NAVIGATION ═══ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btnDashboard"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="4dp" app:cardBackgroundColor="?attr/colorSurfaceContainerHigh" app:cardCornerRadius="12dp"
                app:cardElevation="0dp" app:strokeColor="@color/accent" app:strokeWidth="1dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="📊 Analytics" android:textColor="@color/accent" android:textSize="13sp"
                    android:textStyle="bold" android:gravity="center" android:paddingTop="14dp"
                    android:paddingBottom="14dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/btnSettings"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginStart="4dp" app:cardBackgroundColor="?attr/colorSurfaceContainerHigh" app:cardCornerRadius="12dp"
                app:cardElevation="0dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⚙ Settings" android:textColor="?attr/colorOnSurface" android:textSize="13sp"
                    android:textStyle="bold" android:gravity="center" android:paddingTop="14dp"
                    android:paddingBottom="14dp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView android:id="@+id/btnProcessManager"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" app:cardBackgroundColor="?attr/colorSurfaceContainerHigh" app:cardCornerRadius="12dp"
            app:cardElevation="0dp" app:strokeColor="@color/danger" app:strokeWidth="1dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="💀 Process Manager" android:textColor="@color/danger" android:textSize="13sp"
                android:textStyle="bold" android:gravity="center" android:paddingTop="14dp"
                android:paddingBottom="14dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
