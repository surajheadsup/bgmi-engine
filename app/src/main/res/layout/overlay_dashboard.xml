<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/dashboardCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/overlay_bg"
        android:alpha="0.93">

        <!-- COLLAPSED BAR — always visible, tiny horizontal strip -->
        <LinearLayout
            android:id="@+id/collapsedBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:minWidth="180dp">

            <!-- Engine indicator dot -->
            <View
                android:id="@+id/dotIndicator"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/dot_green" />

            <TextView
                android:id="@+id/tvBarMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡EXT"
                android:textColor="@color/success"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="#33FFFFFF"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/tvBarFps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎮 --"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="#33FFFFFF"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/tvBarTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌡 --°"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="#33FFFFFF"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/tvBarBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔋 --%"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="#33FFFFFF"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/tvBarPing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📶 --"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:background="#33FFFFFF"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp" />

            <TextView
                android:id="@+id/tvBarBrightness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀ --%"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <!-- Expand arrow -->
            <TextView
                android:id="@+id/tvExpandArrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="#666666"
                android:textSize="10sp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- EXPANDED PANEL — hidden by default, shown on tap -->
        <LinearLayout
            android:id="@+id/expandedPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="6dp">

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22FFFFFF" />

            <!-- Stats grid — 2 columns -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <!-- Left column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvExpCpu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPU --"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvExpRam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RAM --"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Right column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvExpSession"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 min"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvExpStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stable"
                        android:textColor="@color/success"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />

                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22FFFFFF"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <!-- Quick toggle buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Voice toggle -->
                <TextView
                    android:id="@+id/btnToggleVoice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Voice ON"
                    android:textColor="@color/success"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/toggle_btn_bg"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="1dp" />

                <!-- Override toggle -->
                <TextView
                    android:id="@+id/btnToggleOverride"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto"
                    android:textColor="@color/success"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/toggle_btn_bg"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="1dp" />

                <!-- Kill BG apps -->
                <TextView
                    android:id="@+id/btnKillApps"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kill BG"
                    android:textColor="@color/warning"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/toggle_btn_bg"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
