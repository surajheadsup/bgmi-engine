<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/colorSurfaceContainerHigh"
    android:paddingStart="10dp"
    android:paddingEnd="6dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:layout_marginBottom="2dp">

    <TextView android:id="@+id/tvWlName" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="?attr/colorOnSurface" android:textSize="12sp"
        android:ellipsize="middle" android:singleLine="true" />

    <TextView android:id="@+id/tvWlCategory" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="USER" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="9sp" android:textStyle="bold"
        android:background="@drawable/mode_badge_bg" android:paddingStart="5dp" android:paddingEnd="5dp"
        android:paddingTop="1dp" android:paddingBottom="1dp" android:layout_marginEnd="8dp" />

    <TextView android:id="@+id/btnWlRemove" android:layout_width="28dp" android:layout_height="28dp"
        android:text="✕" android:textColor="@color/danger" android:textSize="14sp" android:gravity="center"
        android:background="@drawable/toggle_btn_bg" />
</LinearLayout>
