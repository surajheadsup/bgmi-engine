<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Card style — soft corners, subtle elevation -->
    <style name="CardStyle">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="contentPadding">14dp</item>
    </style>

    <!-- Primary action button — filled pill -->
    <style name="BtnPrimary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">36dp</item>
    </style>

    <!-- Outline button — for secondary actions -->
    <style name="BtnOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">20dp</item>
        <item name="android:textSize">11sp</item>
        <item name="strokeColor">@color/accent</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">36dp</item>
    </style>

    <!-- Small text button -->
    <style name="BtnText" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">32dp</item>
    </style>

    <!-- Filter chip — active -->
    <style name="FilterActive">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Header bar style -->
    <style name="HeaderBar">
        <item name="android:background">?attr/colorSurfaceContainerHigh</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:elevation">2dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Header back button -->
    <style name="HeaderBackBtn">
        <item name="android:layout_width">36dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:text">←</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/btn_back</item>
    </style>

    <!-- Header title -->
    <style name="HeaderTitle">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginStart">12dp</item>
    </style>

    <!-- Toggle button style -->
    <style name="ToggleButton">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/toggle_btn_bg</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Title text -->
    <style name="TextTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Section header -->
    <style name="TextSection">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textColor">@color/accent</item>
    </style>

    <!-- Body text -->
    <style name="TextBody">
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Caption/helper text -->
    <style name="TextCaption">
        <item name="android:textSize">11sp</item>
    </style>
</resources>
